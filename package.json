{
  "name": "paul-cli",
  "type": "module",
  "description": "CLI tool for managing tasks and projects via Todoist API",
  "version": "1.0.0",
  "private": true,
  "bin": {
    "paul": "dist/index.js"
  },
  "keywords": [
    "todoist",
    "tasks",
    "projects",
    "cli",
    "management",
    "terminal"
  ],
  "author": "stanleygomes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stanleygomes/paul-cli"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "rm -rf dist && tsc && tsc-alias",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check": "pnpm format:check && pnpm lint && pnpm check-types",
    "fix": "pnpm format:fix && pnpm lint:fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.0.1",
    "axios": "^1.13.6",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.1",
    "date-fns": "^4.1.0",
    "figlet": "^1.9.3",
    "ora": "^8.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "dotenv": "^16.6.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "tsc-alias": "^1.8.16",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
